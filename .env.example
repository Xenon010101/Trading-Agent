# Groq API Keys (get from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_backup_groq_api_key_here

# Kraken API Keys (for live trading - not required for paper mode)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ERC-8004 Agent Configuration
AGENT_PRIVATE_KEY=your_agent_private_key_here
AGENT_ADDRESS=your_agent_address_here
AGENT_ID=33

# Operator Wallet (for blockchain transactions)
OPERATOR_PRIVATE_KEY=your_operator_private_key_here
OPERATOR_ADDRESS=your_operator_address_here

# Trading Mode (True = paper, False = live)
PAPER_MODE=True
